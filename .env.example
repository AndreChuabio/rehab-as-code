# Wellness Coach AI - Environment Variables
# Copy this to .env and fill in your keys

# Claude API (required for context generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Tavus CVI (required for live video avatar)
# Get these from: https://platform.tavus.io
TAVUS_API_KEY=your_tavus_key_here
TAVUS_REPLICA_ID=your_replica_id_here    # The avatar/character
TAVUS_PERSONA_ID=your_persona_id_here    # The persona/voice

# ElevenLabs — voiceover narration for video briefing
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# AIML API — Kling video generation (get key at aimlapi.com)
AIMLAPI_KEY=your_aimlapi_key_here

# Google Calendar (optional - falls back to mock if not set)
# Run setup_gcal.py once to generate these locally
GOOGLE_CREDENTIALS_PATH=../credentials.json
GOOGLE_TOKEN_PATH=../token.pickle

# For Railway deployment, you can provide credentials directly as env vars instead
# of committing credential files.
# GOOGLE_CREDENTIALS_JSON='{...your credentials.json content...}'
# GOOGLE_TOKEN_PICKLE_B64='...base64-encoded token.pickle contents...'

# ------------------------------------------------------------------------
# RehabAsCode: Cursor cloud-agent integration
# ------------------------------------------------------------------------

# Cursor SDK API key. Get from https://cursor.com/dashboard/cloud-agents
# Required only when AGENT_PROVIDER=cursor_sdk (the live orchestrated path).
# CURSOR_API_KEY=cursor_...

# Agent provider selector. The demo default is cached_replay so the live
# API is never on the critical path. Flip to cursor_sdk for live runs.
#   cursor_sdk    -- TS SDK via Node helper (parent + sub-agents)
#   cursor_github -- fallback: @cursor GitHub mention via gh CLI
#   cached_replay -- demo: replay pre-captured traces from cached_runs/
#   mock          -- dev: scripted fake, no network
AGENT_PROVIDER=cached_replay

# When 1, FastAPI routes the agent button through the live provider above.
# When 0 (default), every button press uses cached_replay regardless of
# AGENT_PROVIDER, so the stage demo is deterministic.
DEMO_LIVE_AGENT=0

# Repo the orchestrator targets. Protocols live under protocols/ in the
# same repo as the app — single-repo audit trail judges can skim.
PROTOCOL_REPO=AndreChuabio/rehab-as-code
PROTOCOL_BRANCH=main
PROTOCOL_SUBDIR=protocols
