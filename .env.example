# Wellness Coach AI - Environment Variables
# Copy this to .env and fill in your keys

# Claude API (required for context generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Tavus CVI (required for live video avatar)
# Get these from: https://platform.tavus.io
TAVUS_API_KEY=your_tavus_key_here
TAVUS_REPLICA_ID=your_replica_id_here    # The avatar/character
TAVUS_PERSONA_ID=your_persona_id_here    # The persona/voice
# Shared secret for the BYO-LLM proxy. The Tavus persona's custom-LLM layer
# (llm.api_key) must equal this; the proxy compares it constant-time. Empty
# means the proxy is configured-out (503). Generate with: openssl rand -base64 32
TAVUS_PROXY_SECRET=your_tavus_proxy_secret_here

# ElevenLabs — voiceover narration for video briefing
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# AIML API — Kling video generation (get key at aimlapi.com)
AIMLAPI_KEY=your_aimlapi_key_here

# Google Calendar (optional - falls back to mock if not set)
# Run setup_gcal.py once to generate these locally
GOOGLE_CREDENTIALS_PATH=../credentials.json
GOOGLE_TOKEN_PATH=../token.pickle

# For Railway deployment, you can provide credentials directly as env vars instead
# of committing credential files.
# GOOGLE_CREDENTIALS_JSON='{...your credentials.json content...}'
# GOOGLE_TOKEN_PICKLE_B64='...base64-encoded token.pickle contents...'

# ------------------------------------------------------------------------
# RehabAsCode: Cursor cloud-agent integration
# ------------------------------------------------------------------------

# Cursor SDK API key. Get from https://cursor.com/dashboard/cloud-agents
# Required only when AGENT_PROVIDER=cursor_sdk (the live orchestrated path).
# CURSOR_API_KEY=cursor_...

# Agent provider selector. The demo default is cached_replay so the live
# API is never on the critical path. Flip to cursor_sdk for live runs.
#   cursor_sdk    -- TS SDK via Node helper (parent + sub-agents)
#   cursor_github -- fallback: @cursor GitHub mention via gh CLI
#   cached_replay -- demo: replay pre-captured traces from cached_runs/
#   mock          -- dev: scripted fake, no network
AGENT_PROVIDER=cached_replay

# When 1, FastAPI routes the agent button through the live provider above.
# When 0 (default), every button press uses cached_replay regardless of
# AGENT_PROVIDER, so the stage demo is deterministic.
DEMO_LIVE_AGENT=0

# Repo the orchestrator targets. Protocols live under protocols/ in the
# same repo as the app — single-repo audit trail judges can skim.
PROTOCOL_REPO=AndreChuabio/rehab-as-code
PROTOCOL_BRANCH=main
PROTOCOL_SUBDIR=protocols

# ------------------------------------------------------------------------
# Coach chat co-pilot (OpenAI)
# ------------------------------------------------------------------------
# Powers the in-app chat that recommends exercises with embedded videos and
# fires the same orchestrator triggers as the 4 buttons.
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Open Wearables (optional read-only source for normalized wearable data)
# If HEALTH_DATA_SOURCE=auto, backend will use Open Wearables when all three
# values below are set; otherwise it falls back to Apple cache/mock.
OPEN_WEARABLES_API_URL=http://localhost:8000
OPEN_WEARABLES_API_KEY=sk-your-open-wearables-key
OPEN_WEARABLES_USER_ID=your-open-wearables-user-uuid

# Health data source mode:
# - auto (default): Open Wearables if configured, else Apple cache/mock
# - open_wearables: force Open Wearables (still falls back on request failure)
# - apple_cache: skip Open Wearables and use existing Apple cache/mock path
HEALTH_DATA_SOURCE=auto

# Junction (the rebrand of Vital) - real wearable aggregator (300+ devices via
# one API). When a patient connects a device, their REAL sleep/HRV/recovery
# flows through get_health_data; not-connected/fetch-fail degrades to mock.
# The Team API key is a SECRET: server-side only, never client-side, never
# committed. Read at call time. Sandbox can simulate a connection without a real
# device via POST /v2/link/connect/demo (see /api/junction/demo-connect).
VITAL_API_KEY=your_junction_team_api_key   # alias JUNCTION_API_KEY also honored
JUNCTION_ENV=sandbox                        # sandbox | production
JUNCTION_REGION=us                          # us | eu
# Hosted-Link return URL; frontend keys the post-return refresh off ?state=success
JUNCTION_REDIRECT_URL=https://your-dashboard/?state=success
# Optional explicit base-URL override (else composed from ENV+REGION)
# JUNCTION_API_BASE=https://api.sandbox.us.junction.com
# Only needed if the svix-signed webhook receiver is built later (prod upgrade)
JUNCTION_WEBHOOK_SECRET=

# ------------------------------------------------------------------------
# User store backend
# ------------------------------------------------------------------------
# Per-user records (intake, protocol_state, session_history, health) live
# in one of three backends. Public API in user_store.py is identical for all.
#   sqlite   (default)  — `users.db` next to repo root. Local dev only;
#                          Vercel serverless filesystem is ephemeral so this
#                          will lose data per-invocation in production.
#   postgres            — Supabase, Vercel Postgres, Neon, or local PG via
#                          DATABASE_URL. Production target.
#   flatfile            — legacy `users/{token}.json`, kept for rollback.
STORAGE_BACKEND=sqlite

# Supabase / Postgres connection string. Required when STORAGE_BACKEND=postgres.
#
# Schema bootstrap on Supabase: connect this repo to your Supabase project
# (Settings → Integrations → GitHub) with "Deploy to production" ON. Every
# push to main runs the SQL files in supabase/migrations/ against your
# Postgres instance — no manual schema step needed.
#
# Schema bootstrap on non-Supabase Postgres (Neon, Vercel PG, Railway,
# self-hosted): run the equivalent script once:
#   export DATABASE_URL="postgresql://..."
#   cd backend && python -m scripts.setup_supabase_schema
#
# Connection string conventions:
#   * Local dev / DDL bootstrap: direct URL (port 5432)
#       postgresql://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
#   * Vercel serverless / production: transaction pooler URL (port 6543)
#       postgresql://postgres:<pwd>@db.<ref>.pooler.supabase.com:6543/postgres
#     The pooler multiplexes short-lived function connections cleanly.
#
# Validate the live DB end-to-end:
#   STORAGE_BACKEND=postgres python -m scripts.smoke_test_user_store
DATABASE_URL=

# ------------------------------------------------------------------------
# Supabase Auth (HS256 JWT verification on /chat)
# ------------------------------------------------------------------------
# The web-UI chat surface is gated by a Supabase-issued JWT. The frontend
# obtains it via @supabase/supabase-js (magic-link or password sign-in)
# and sends it as `Authorization: Bearer <jwt>` on every /chat call.
# backend/auth.py verifies HS256 against SUPABASE_JWT_SECRET.
#
# Slack and iOS-shortcut flows still use the legacy UUID-bearer model —
# auth only applies to logged-in browser sessions.
#
# Where to find each value in Supabase:
#   SUPABASE_URL          -- Project Settings → API → Project URL
#   SUPABASE_JWT_SECRET   -- Project Settings → API → JWT Settings → JWT Secret
#                            (NOT the anon key, NOT the service_role key)
#   SUPABASE_ANON_KEY     -- Project Settings → API → Project API keys → anon/public
#                            (only the frontend needs this; safe to expose)
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
